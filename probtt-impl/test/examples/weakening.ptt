-- Test weight weakening rule
-- t-weaken: if Γ ⊢ t : A @ w and v ≤ w, then Γ ⊢ t : A @ v
-- A proof at weight 1 can be used at any lower weight

-- Weight 1 proof can be used at weight 0 (vacuously true)
id0 : A → A @ 0
id0 x = x

-- Weight 1 proof at weight 1 (normal case)
id1 : A → A @ 1
id1 x = x

-- Const at weight 0
const0 : A → B → A @ 0
const0 x y = x
