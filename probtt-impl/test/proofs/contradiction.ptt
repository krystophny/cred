-- Proof by contradiction (classical limit)
-- Assume ¬A at weight w, derive contradiction, conclude A at weight 1

postulate not_a : NotA 〔 w 〕

-- From ¬A we derive some P
derive p : P 〔 w 〕 from not_a by consequence1

-- From ¬A we also derive ¬P
derive not_p : NotP 〔 w 〕 from not_a by consequence2

-- P and ¬P contradict
contradict p not_p

-- Therefore A (negation of our assumption)
conclude a from not_a
