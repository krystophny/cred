-- ProbTT Proof: √2 is irrational
--
-- This proof demonstrates weight tracking through contradiction.
-- We assume "√2 is rational" at unknown weight w, derive a
-- contradiction, forcing w = 0, so the negation has weight 1.

-- Assume √2 = p/q in lowest terms, at weight w
postulate sqrt2_rational : Rational 〔 w 〕

-- From "lowest terms", gcd(p,q) = 1
postulate gcd_is_1 : GCD_1 〔 w 〕

-- Derive consequences (each step preserves weight)
derive p_even : Even_p 〔 w 〕 from sqrt2_rational by algebra
derive q_even : Even_q 〔 w 〕 from p_even by substitution
derive gcd_geq_2 : GCD_geq_2 〔 w 〕 from q_even by both_even

-- These contradict: gcd=1 and gcd≥2 cannot both hold
contradict gcd_is_1 gcd_geq_2

-- Conclusion: since w = 0, the negation has weight ¬0 = 1
conclude sqrt2_irrational from sqrt2_rational
