-- Test credence weakening rule
-- t-weaken: if Gamma entails t : A @ c and v <= c, then Gamma entails t : A @ v
-- A proof at credence 1 can be used at any lower credence

-- Credence 1 proof can be used at credence 0 (vacuously true)
id0 : A → A 〔 0 〕
id0 x = x

-- Credence 1 proof at credence 1 (normal case)
id1 : A → A 〔 1 〕
id1 x = x

-- Const at credence 0
const0 : A → B → A 〔 0 〕
const0 x y = x
