-- Implicit arguments test

-- Polymorphic identity with implicit type argument
id : {A : Set} → A → A
id x = x

-- Polymorphic const with implicit type arguments
const : {A : Set} → {B : Set} → A → B → A
const x y = x

-- Using forall notation (separate bindings)
compose : ∀ {A : Set} → ∀ {B : Set} → ∀ {C : Set} → (A → B) → (B → C) → A → C
compose f g x = g (f x)
