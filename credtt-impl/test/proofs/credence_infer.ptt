-- CredTT Proof: Credence inference test
--
-- This proof demonstrates automatic credence inference.
-- When credence is specified as _, it will be inferred from context.

-- Assume P at unknown credence (will be inferred)
postulate p : P 〔 c 〕

-- Derive Q from P - credence should be inferred as c
derive q : Q 〔 c 〕 from p by implication

-- Derive R from Q - credence chain preserved
derive r : R 〔 c 〕 from q by transitivity

-- All derivations should have the same inferred credence c
