-- Modus tollens at credence 1 (classical limit)
-- not B, A->B entails not A
-- If A implies B, and B is false, then A is false

postulate a : A 〔 c 〕
postulate a_implies_b : A_implies_B 〔 1 〕
derive b : B 〔 c 〕 from a by a_implies_b
postulate not_b : NotB 〔 1 〕

-- b and not_b contradict at credence c
contradict b not_b

-- Therefore not A at credence 1
conclude not_a from a
