-- Proof by contradiction (classical limit)
-- Assume not A at credence c, derive contradiction, conclude A at credence 1

postulate not_a : NotA 〔 c 〕

-- From not A we derive some P
derive p : P 〔 c 〕 from not_a by consequence1

-- From not A we also derive not P
derive not_p : NotP 〔 c 〕 from not_a by consequence2

-- P and not P contradict
contradict p not_p

-- Therefore A (negation of our assumption)
conclude a from not_a
