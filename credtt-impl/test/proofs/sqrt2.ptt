-- CredTT Proof: sqrt(2) is irrational
--
-- This proof demonstrates credence tracking through contradiction.
-- We assume "sqrt(2) is rational" at unknown credence c, derive a
-- contradiction, forcing c = 0, so the negation has credence 1.

-- Assume sqrt(2) = p/q in lowest terms, at credence c
postulate sqrt2_rational : Rational 〔 c 〕

-- From "lowest terms", gcd(p,q) = 1
postulate gcd_is_1 : GCD_1 〔 c 〕

-- Derive consequences (each step preserves credence)
derive p_even : Even_p 〔 c 〕 from sqrt2_rational by algebra
derive q_even : Even_q 〔 c 〕 from p_even by substitution
derive gcd_geq_2 : GCD_geq_2 〔 c 〕 from q_even by both_even

-- These contradict: gcd=1 and gcd>=2 cannot both hold
contradict gcd_is_1 gcd_geq_2

-- Conclusion: since c = 0, the negation has credence neg 0 = 1
conclude sqrt2_irrational from sqrt2_rational
