-- Double negation elimination (classical)
-- not not A entails A
-- In CredTT: if not A has credence 0, then A has credence 1

postulate not_not_a : NotNotA 〔 1 〕
postulate not_a : NotA 〔 c 〕

-- not not A and not A contradict
contradict not_not_a not_a

-- c = 0, so not(not A) = A has credence 1
conclude a from not_a
