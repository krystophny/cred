-- Proof by Cases (Case Analysis)
--
-- Classical: If A|B and (A->C) and (B->C), then C
-- CredTT: Each branch stable -> result stable; unstable branch -> unstable result
--
-- Example: Prove |n| >= 0 by cases on sign of n
-- Case 1: n >= 0, then |n| = n >= 0
-- Case 2: n < 0, then |n| = -n > 0 >= 0

-- Classical gives: C is definitely true
-- CredTT gives: C at credence min(c1, c2) with combined stability

-- Case 1: Non-negative case at credence c1
postulate case_nonneg : abs_n_geq_0_when_nonneg @ c1

-- Case 2: Negative case at credence c2
postulate case_neg : abs_n_geq_0_when_neg @ c2

-- In classical logic: both cases proven -> conclusion proven
-- In CredTT: stability of result depends on BOTH branches

-- If both branches are stable, result is stable
-- If either branch is unstable, result may be unstable

-- Stable branches (credence 1)
postulate stable_case1 : case1_result @ 1
postulate stable_case2 : case2_result @ 1

-- Both stable -> result stable
stable stable_case1
stable stable_case2

-- Weak branch (credence c < 1)
postulate weak_case : weak_result @ c

-- Combining stable and weak:
-- stable * weak = weak (credence degrades)
-- This is the honest tracking that classical logic hides

-- The KEY difference from MLTT:
-- MLTT: case analysis always gives definite result
-- CredTT: case analysis tracks stability through branches
