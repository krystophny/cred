-- Dual Proofs (CredTT-Native #7)
--
-- NEW: Lower bound for A + upper bound for neg A = squeezed region
-- Constrain credence from BOTH directions
--
-- Example: Prove 0.4 <= c(A) <= 0.6

-- Classical: A is true or false, no squeezing
-- CredTT: c(A) can be constrained to interval

-- LOWER BOUND: prove c(A) >= l
postulate lower : A_at_least @ 4/10

-- UPPER BOUND: prove c(A) <= u
-- Equivalently: c(neg A) >= 1 - u

postulate upper : A_at_most @ 6/10

-- SQUEEZED: l <= c(A) <= u
-- c(A) is in interval [0.4, 0.6]

-- This is the GODEL REGION:
-- Neither definitely true (c < 1)
-- Nor definitely false (c > 0)
-- But constrained to specific interval

-- The Godel sentence:
-- Lower bound: c(G) >= 0.5 (self-reference lower bound)
-- Upper bound: c(G) <= 0.5 (self-reference upper bound)
-- Squeezed: c(G) = 0.5 exactly

fixpoint godel_c = neg godel_c
-- Solved: godel_c = 1/2
-- This IS the squeezed point!

-- DUAL PROOF TECHNIQUE:
-- 1. Prove A from below (lower bound)
-- 2. Prove A from above (upper bound)
-- 3. Combine for tight bound

-- Example: Scientific measurement
-- Theory predicts X = 42 +/- 0.5
-- Lower: X >= 41.5
-- Upper: X <= 42.5
-- Squeezed: X in [41.5, 42.5]

-- WHY DUAL PROOFS MATTER:
-- They give PRECISION on credence
-- Not just "probably true" but "true with credence in [l, u]"

-- Error analysis:
-- Measurement A @ [0.9, 0.95]
-- Measurement B @ [0.85, 0.9]
-- Combined @ [0.9*0.85, 0.95*0.9] = [0.765, 0.855]

-- Propagate intervals, not just points!
