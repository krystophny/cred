-- Modus Ponens (Function Application)
--
-- STATUS: CONCEPTUAL (Issue #169)
-- This file EXPLAINS the fundamental CredTT rule: credences multiply in
-- elimination. The checker DOES implement this (see check.ml App case),
-- but the .ctt syntax here is DIDACTIC - it demonstrates the concept
-- without verifiable execution. The 'by apply' tactic is an annotation.
-- To verify this rule works: write OCaml tests against the type checker.
--
-- Classical: A, A -> B |- B
-- CredTT: f : A -> B @ c1, a : A @ c2 |- f a : B @ c1 * c2
--         Credences MULTIPLY in application!
--
-- Example: If rain then wet; it's raining; therefore wet
-- Classical: Definite conclusion
-- CredTT: Conclusion credence = product of premise credences

-- This is the FUNDAMENTAL rule of CredTT:
-- CREDENCES MULTIPLY IN ELIMINATION

-- Function at credence 1 (certain)
postulate f : A_to_B @ 1

-- Argument at credence c (uncertain)
postulate a : A @ c

-- Application: result credence = 1 * c = c
derive b : B @ c from a by apply

-- Now both uncertain:
postulate f2 : A_to_B @ c1
postulate a2 : A @ c2

-- Application: result credence = c1 * c2
-- DEGRADATION: c1 * c2 <= min(c1, c2)

-- Example with numbers:
-- f @ 0.9, a @ 0.8 -> f a @ 0.72
-- Not 0.9 or 0.8, but 0.72!

-- This is the CHAIN RULE: P(B) = P(B|A) * P(A)
-- f is P(B|A), a is P(A), result is P(B)

-- Why this matters:
-- Classical: "If probably P then Q" and "probably P" gives "Q"
-- CredTT: "If P then Q @ 0.9" and "P @ 0.8" gives "Q @ 0.72"
--
-- The uncertainty ACCUMULATES honestly

-- Stability propagation:
-- Stable1 * Stable1 = Stable1
-- Anything with Unstable0 = Unstable0
-- Interior * anything = Interior or worse

-- If both function and argument are stable (near 1),
-- result is stable (product near 1)

-- If either is unstable (near 0),
-- result is unstable (product near 0)

postulate stable_f : stable_func @ 1
postulate stable_a : stable_arg @ 1
derive stable_result : result @ 1 from stable_a by apply

stable stable_f
stable stable_a
stable stable_result
